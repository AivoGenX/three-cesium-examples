<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="quantumGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00ff88;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0088ff;stop-opacity:1" />
    </linearGradient>
    <filter id="quantumGlow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge> 
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  <rect width="100%" height="100%" fill="#000"/>
  <circle cx="150" cy="100" r="60" fill="url(#quantumGradient)" filter="url(#quantumGlow)" opacity="0.8"/>
  <circle cx="150" cy="100" r="40" fill="none" stroke="#00ff88" stroke-width="2" stroke-dasharray="5,5" opacity="0.6"/>
  <circle cx="150" cy="100" r="20" fill="none" stroke="#0088ff" stroke-width="1" stroke-dasharray="3,3" opacity="0.4"/>
</svg>