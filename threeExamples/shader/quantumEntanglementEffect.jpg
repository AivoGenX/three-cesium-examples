<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="quantumBg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#003366;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#001122;stop-opacity:1" />
    </radialGradient>
    <linearGradient id="quantumGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#66ffcc;stop-opacity:0.9" />
      <stop offset="50%" style="stop-color:#ff66ff;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#66ffff;stop-opacity:0.7" />
    </linearGradient>
  </defs>
  
  <rect width="100%" height="100%" fill="url(#quantumBg)"/>
  
  <!-- 纠缠粒子 -->
  <circle cx="120" cy="100" r="25" fill="url(#quantumGradient)" opacity="0.9">
    <animate attributeName="cx" dur="3s" repeatCount="indefinite" values="120;125;120"/>
  </circle>
  <circle cx="180" cy="100" r="25" fill="url(#quantumGradient)" opacity="0.9">
    <animate attributeName="cx" dur="3s" repeatCount="indefinite" values="180;175;180"/>
  </circle>
  
  <!-- 纠缠连接 -->
  <path d="M120,100 L180,100" fill="none" stroke="#66ffcc" stroke-width="3" stroke-dasharray="5,5" opacity="0.7">
    <animate attributeName="stroke-dashoffset" dur="2s" repeatCount="indefinite" values="0;10;0"/>
  </path>
  
  <!-- 量子粒子 -->
  <circle cx="100" cy="80" r="2" fill="#ffffff" opacity="0.8">
    <animate attributeName="opacity" dur="1.5s" repeatCount="indefinite" values="0.3;0.9;0.3"/>
  </circle>
  <circle cx="200" cy="120" r="1.5" fill="#ffffff" opacity="0.7">
    <animate attributeName="opacity" dur="2s" repeatCount="indefinite" values="0.4;0.8;0.4"/>
  </circle>
  
  <!-- 标题 -->
  <text x="150" y="180" text-anchor="middle" fill="#66ffcc" font-family="Arial" font-size="14" font-weight="bold">
    量子纠缠效果
  </text>
</svg>