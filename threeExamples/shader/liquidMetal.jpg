<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="metalGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#cccccc;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#666666;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="100%" height="100%" fill="#333333"/>
  <rect x="120" y="80" width="160" height="140" fill="url(#metalGradient)" opacity="0.9"/>
  <circle cx="150" cy="120" r="15" fill="#ffffff" opacity="0.8"/>
  <circle cx="250" cy="120" r="15" fill="#ffffff" opacity="0.8"/>
  <ellipse cx="200" cy="180" rx="40" ry="20" fill="#ffffff" opacity="0.7"/>
  <text x="200" y="280" text-anchor="middle" fill="#cccccc" font-family="Arial" font-size="16">液态金属</text>
</svg>