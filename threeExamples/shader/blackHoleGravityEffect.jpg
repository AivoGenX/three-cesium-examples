<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="blackholeBg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#000000;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#111111;stop-opacity:1" />
    </radialGradient>
    <radialGradient id="blackholeGradient" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#ff5500;stop-opacity:0.9" />
      <stop offset="50%" style="stop-color:#ffff00;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#ff3300;stop-opacity:0.7" />
    </radialGradient>
  </defs>
  
  <rect width="100%" height="100%" fill="url(#blackholeBg)"/>
  
  <!-- 黑洞 -->
  <circle cx="150" cy="100" r="50" fill="url(#blackholeGradient)" opacity="0.9">
    <animate attributeName="r" dur="2s" repeatCount="indefinite" values="50;55;50"/>
  </circle>
  
  <!-- 吸积盘 -->
  <circle cx="150" cy="100" r="70" fill="none" stroke="#ff5500" stroke-width="8" opacity="0.7">
    <animate attributeName="r" dur="3s" repeatCount="indefinite" values="70;75;70"/>
  </circle>
  
  <!-- 粒子效果 -->
  <circle cx="130" cy="70" r="2" fill="#ffffff" opacity="0.8">
    <animate attributeName="cx" dur="2s" repeatCount="indefinite" values="130;135;130"/>
    <animate attributeName="opacity" dur="2s" repeatCount="indefinite" values="0.3;0.9;0.3"/>
  </circle>
  <circle cx="170" cy="130" r="1.5" fill="#ffffff" opacity="0.7">
    <animate attributeName="cx" dur="1.5s" repeatCount="indefinite" values="170;165;170"/>
    <animate attributeName="opacity" dur="1.5s" repeatCount="indefinite" values="0.4;0.8;0.4"/>
  </circle>
  
  <!-- 旋转效果 -->
  <path d="M150,30 L155,35 L150,40 L145,35 Z" fill="#ffff00" opacity="0.6">
    <animateTransform attributeName="transform" type="rotate" from="0 150 100" to="360 150 100" dur="8s" repeatCount="indefinite"/>
  </path>
  
  <!-- 标题 -->
  <text x="150" y="180" text-anchor="middle" fill="#ff5500" font-family="Arial" font-size="14" font-weight="bold">
    黑洞引力效果
  </text>
</svg>