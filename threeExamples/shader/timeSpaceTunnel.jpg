<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="tunnelGradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#ff6600;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#663300;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="100%" height="100%" fill="#000033"/>
  <ellipse cx="200" cy="150" rx="120" ry="60" fill="url(#tunnelGradient)" opacity="0.7"/>
  <ellipse cx="200" cy="150" rx="80" ry="40" fill="#ff9900" opacity="0.8"/>
  <ellipse cx="200" cy="150" rx="40" ry="20" fill="#ffffff" opacity="0.9"/>
  <circle cx="100" cy="80" r="5" fill="#ffffff" opacity="0.8"/>
  <circle cx="300" cy="120" r="5" fill="#ffffff" opacity="0.8"/>
  <circle cx="150" cy="220" r="5" fill="#ffffff" opacity="0.8"/>
  <text x="200" y="280" text-anchor="middle" fill="#ff6600" font-family="Arial" font-size="16">时空扭曲隧道</text>
</svg>