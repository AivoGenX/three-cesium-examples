<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="lavaBg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#330000;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#110000;stop-opacity:1" />
    </radialGradient>
    <radialGradient id="lavaGradient" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#ff5500;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#ff3300;stop-opacity:0.9" />
      <stop offset="100%" style="stop-color:#ff1100;stop-opacity:0.7" />
    </radialGradient>
  </defs>
  
  <rect width="100%" height="100%" fill="url(#lavaBg)"/>
  
  <!-- 熔岩球体 -->
  <circle cx="150" cy="100" r="60" fill="url(#lavaGradient)" opacity="0.9">
    <animate attributeName="r" dur="2s" repeatCount="indefinite" values="60;65;60"/>
  </circle>
  
  <!-- 熔岩流动效果 -->
  <path d="M90,100 Q120,80 150,100 T210,100" fill="none" stroke="#ffaa00" stroke-width="8" stroke-linecap="round" opacity="0.8">
    <animate attributeName="d" dur="2s" repeatCount="indefinite" 
             values="M90,100 Q120,80 150,100 T210,100; M90,100 Q120,120 150,100 T210,100; M90,100 Q120,80 150,100 T210,100"/>
  </path>
  
  <!-- 气泡效果 -->
  <circle cx="130" cy="85" r="3" fill="#ffff00" opacity="0.7">
    <animate attributeName="cy" dur="1.5s" repeatCount="indefinite" values="85;75;85"/>
    <animate attributeName="opacity" dur="1.5s" repeatCount="indefinite" values="0.3;0.9;0.3"/>
  </circle>
  <circle cx="170" cy="115" r="2" fill="#ffff00" opacity="0.6">
    <animate attributeName="cy" dur="2s" repeatCount="indefinite" values="115;105;115"/>
    <animate attributeName="opacity" dur="2s" repeatCount="indefinite" values="0.2;0.8;0.2"/>
  </circle>
  
  <!-- 标题 -->
  <text x="150" y="180" text-anchor="middle" fill="#ff5500" font-family="Arial" font-size="14" font-weight="bold">
    熔岩流动效果
  </text>
</svg>