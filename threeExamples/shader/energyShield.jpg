<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="shieldGradient" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#00ffff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#006666;stop-opacity:1" />
    </radialGradient>
  </defs>
  <rect width="100%" height="100%" fill="#003366"/>
  <circle cx="200" cy="150" r="80" fill="url(#shieldGradient)" opacity="0.8"/>
  <circle cx="200" cy="150" r="60" fill="#00cccc" opacity="0.7"/>
  <polygon points="200,70 230,110 200,150 170,110" fill="#ffffff" opacity="0.9"/>
  <polygon points="200,150 230,190 200,230 170,190" fill="#ffffff" opacity="0.9"/>
  <text x="200" y="280" text-anchor="middle" fill="#00ffff" font-family="Arial" font-size="16">能量护盾</text>
</svg>