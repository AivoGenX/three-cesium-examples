  <defs>
    <radialGradient id="nebulaGradient" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#ff9900;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#663300;stop-opacity:1" />
    </radialGradient>
