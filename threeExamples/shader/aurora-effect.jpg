<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="auroraBg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#001122;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#000011;stop-opacity:1" />
    </radialGradient>
    <linearGradient id="auroraGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00ffcc;stop-opacity:0.8" />
      <stop offset="50%" style="stop-color:#ff66cc;stop-opacity:0.9" />
      <stop offset="100%" style="stop-color:#66ffff;stop-opacity:0.8" />
    </linearGradient>
  </defs>
  
  <rect width="100%" height="100%" fill="url(#auroraBg)"/>
  
  <!-- 极光效果 -->
  <path d="M0,100 Q75,60 150,100 T300,100" fill="none" stroke="url(#auroraGradient)" stroke-width="15" stroke-linecap="round" opacity="0.8">
    <animate attributeName="d" dur="3s" repeatCount="indefinite" 
             values="M0,100 Q75,60 150,100 T300,100; M0,100 Q75,140 150,100 T300,100; M0,100 Q75,60 150,100 T300,100"/>
  </path>
  
  <!-- 星星效果 -->
  <circle cx="50" cy="40" r="2" fill="#ffffff" opacity="0.8">
    <animate attributeName="opacity" dur="2s" repeatCount="indefinite" values="0.3;0.9;0.3"/>
  </circle>
  <circle cx="250" cy="60" r="1.5" fill="#ffffff" opacity="0.7">
    <animate attributeName="opacity" dur="1.5s" repeatCount="indefinite" values="0.4;0.8;0.4"/>
  </circle>
  <circle cx="180" cy="30" r="1" fill="#ffffff" opacity="0.6">
    <animate attributeName="opacity" dur="2.5s" repeatCount="indefinite" values="0.2;0.7;0.2"/>
  </circle>
  
  <!-- 标题 -->
  <text x="150" y="180" text-anchor="middle" fill="#00ffcc" font-family="Arial" font-size="14" font-weight="bold">
    极光效果
  </text>
</svg>