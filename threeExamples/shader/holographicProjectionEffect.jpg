<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="hologramBg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#003300;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#001100;stop-opacity:1" />
    </radialGradient>
    <linearGradient id="hologramGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#66ff66;stop-opacity:0.9" />
      <stop offset="50%" style="stop-color:#ff66ff;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#66ffff;stop-opacity:0.7" />
    </linearGradient>
  </defs>
  
  <rect width="100%" height="100%" fill="url(#hologramBg)"/>
  
  <!-- 全息立方体 -->
  <rect x="120" y="70" width="60" height="60" fill="url(#hologramGradient)" opacity="0.8">
    <animate attributeName="opacity" dur="3s" repeatCount="indefinite" values="0.6;0.9;0.6"/>
  </rect>
  
  <!-- 全息网格 -->
  <line x1="120" y1="70" x2="180" y2="70" stroke="#66ff66" stroke-width="1" opacity="0.6"/>
  <line x1="120" y1="90" x2="180" y2="90" stroke="#66ff66" stroke-width="1" opacity="0.6"/>
  <line x1="120" y1="110" x2="180" y2="110" stroke="#66ff66" stroke-width="1" opacity="0.6"/>
  <line x1="120" y1="130" x2="180" y2="130" stroke="#66ff66" stroke-width="1" opacity="0.6"/>
  
  <!-- 扫描线 -->
  <line x1="120" y1="80" x2="180" y2="80" stroke="#ffffff" stroke-width="2" opacity="0.7">
    <animate attributeName="y1" dur="2s" repeatCount="indefinite" values="70;130;70"/>
    <animate attributeName="y2" dur="2s" repeatCount="indefinite" values="70;130;70"/>
  </line>
  
  <!-- 标题 -->
  <text x="150" y="180" text-anchor="middle" fill="#66ff66" font-family="Arial" font-size="14" font-weight="bold">
    全息投影效果
  </text>
</svg>