<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="runeBg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#220033;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#110022;stop-opacity:1" />
    </radialGradient>
    <radialGradient id="runeGradient" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#ff66cc;stop-opacity:0.9" />
      <stop offset="50%" style="stop-color:#66ffff;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#66ff66;stop-opacity:0.7" />
    </radialGradient>
  </defs>
  
  <rect width="100%" height="100%" fill="url(#runeBg)"/>
  
  <!-- 魔法符文圆环 -->
  <circle cx="150" cy="100" r="50" fill="none" stroke="url(#runeGradient)" stroke-width="8" opacity="0.9">
    <animate attributeName="r" dur="2s" repeatCount="indefinite" values="50;55;50"/>
  </circle>
  
  <!-- 符文图案 -->
  <path d="M150,50 L160,70 L140,70 Z" fill="#ff66cc" opacity="0.8">
    <animate attributeName="opacity" dur="2s" repeatCount="indefinite" values="0.6;0.9;0.6"/>
  </path>
  <path d="M150,150 L140,130 L160,130 Z" fill="#66ffff" opacity="0.8">
    <animate attributeName="opacity" dur="2s" repeatCount="indefinite" values="0.6;0.9;0.6"/>
  </path>
  
  <!-- 能量流动 -->
  <path d="M150,50 Q170,100 150,150 T130,100" fill="none" stroke="#66ff66" stroke-width="3" stroke-linecap="round" opacity="0.7">
    <animate attributeName="d" dur="3s" repeatCount="indefinite" 
             values="M150,50 Q170,100 150,150 T130,100; M150,50 Q130,100 150,150 T170,100; M150,50 Q170,100 150,150 T130,100"/>
  </path>
  
  <!-- 粒子效果 -->
  <circle cx="130" cy="80" r="2" fill="#ffffff" opacity="0.8">
    <animate attributeName="opacity" dur="1.5s" repeatCount="indefinite" values="0.3;0.9;0.3"/>
  </circle>
  <circle cx="170" cy="120" r="1.5" fill="#ffffff" opacity="0.7">
    <animate attributeName="opacity" dur="2s" repeatCount="indefinite" values="0.4;0.8;0.4"/>
  </circle>
  
  <!-- 旋转效果 -->
  <path d="M150,30 L155,35 L150,40 L145,35 Z" fill="#66ffff" opacity="0.6">
    <animateTransform attributeName="transform" type="rotate" from="0 150 100" to="360 150 100" dur="6s" repeatCount="indefinite"/>
  </path>
  
  <!-- 标题 -->
  <text x="150" y="180" text-anchor="middle" fill="#ff66cc" font-family="Arial" font-size="14" font-weight="bold">
    魔法符文效果
  </text>
</svg>